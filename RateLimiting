# app/security.py
from fastapi import Request, HTTPException, status
import time

# Almacén simple en memoria (podemos moverlo a Redis luego si escala)
request_history = {}

async def rate_limit_middleware(request: Request, call_next):
    client_ip = request.client.host
    current_time = time.time()
    
    # Permitir máximo 100 peticiones por minuto por IP
    if client_ip in request_history and current_time - request_history[client_ip] < 0.6:
        raise HTTPException(status_code=status.HTTP_429_TOO_MANY_REQUESTS, detail="Too many requests")
    
    request_history[client_ip] = current_time
    response = await call_next(request)
    return response
